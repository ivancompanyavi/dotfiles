#!/usr/bin/env bash
# Theme colors (ROLE_*) from the active theme.
source "$CONFIG_DIR/environment.sh"
source "$THEME_DIR/palette.sh"

STATUS_LABEL=$(lsappinfo info -only StatusLabel "{{ .apps.telegram.appName }}")
ICON=""
if [[ $STATUS_LABEL =~ \"label\"=\"([^\"]*)\" ]]; then
    LABEL="${BASH_REMATCH[1]}"

    if [[ $LABEL == "" ]]; then
        ICON_COLOR="$ROLE_OK"
    elif [[ $LABEL == "•" ]]; then
        ICON_COLOR="$ROLE_WARN"
    elif [[ $LABEL =~ ^[0-9]+$ ]]; then
        ICON_COLOR="$ROLE_URGENT"
    else
        exit 0
    fi
else
    LABEL="•"
    ICON_COLOR="$ROLE_ACCENT"
fi

sketchybar --set $NAME icon=$ICON label="${LABEL}" icon.color=${ICON_COLOR}
