#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────────────────────────
# theme-helium — align Helium's (Chromium) autogenerated theme color with the
# active system theme's accent.
#
# Chromium reads browser.theme.* from the profile's Preferences only at launch
# and REWRITES that file from memory on exit. So a write only sticks while
# Helium is not running; editing a live browser is futile (it gets clobbered on
# quit). We therefore write only when Helium is closed, and the new chrome color
# shows on the next launch. Launching through `theme-helium open` (wired to the
# aerospace alt-b binding) guarantees the color is current every time.
#
#   theme-helium apply    write the accent into Preferences if Helium is closed
#   theme-helium open     apply (while closed) then launch/focus Helium
# ─────────────────────────────────────────────────────────────────────────────
set -euo pipefail
export PATH="/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:$PATH"

THEME_HOME="${THEME_HOME:-$HOME/.config/theme}"
RESOLVE="$THEME_HOME/lib/resolve.sh"
PREFS="$HOME/Library/Application Support/net.imput.helium/Default/Preferences"

helium_running() { pgrep -f "Helium.app/Contents/MacOS/Helium" >/dev/null 2>&1; }

write_prefs() {
  [ -f "$PREFS" ] || { echo "theme-helium: no Helium profile yet — skipping" >&2; return 0; }
  local accent; accent="$(bash "$RESOLVE" role accent)"   # #rrggbb
  ACCENT="$accent" PREFS="$PREFS" python3 - <<'PY'
import json, os, tempfile
prefs  = os.environ['PREFS']
accent = os.environ['ACCENT'].lstrip('#')
r, g, b = int(accent[0:2], 16), int(accent[2:4], 16), int(accent[4:6], 16)
argb   = (0xFF << 24) | (r << 16) | (g << 8) | b
signed = argb - (1 << 32) if argb >= (1 << 31) else argb  # SkColor is a signed int32
with open(prefs) as f:
    d = json.load(f)
theme = d.setdefault('browser', {}).setdefault('theme', {})
theme['user_color2']   = signed   # seed color for Chromium's Material palette
theme['is_grayscale2'] = False     # turn off the grayscale theme
# Atomic replace so a crash mid-write can't corrupt the profile.
fd, tmp = tempfile.mkstemp(dir=os.path.dirname(prefs))
with os.fdopen(fd, 'w') as f:
    json.dump(d, f, separators=(',', ':'))
os.replace(tmp, prefs)
print(f"theme-helium: Helium accent set to #{accent}")
PY
}

case "${1:-apply}" in
  apply)
    if helium_running; then
      echo "theme-helium: Helium is open — new theme applies next launch (alt-b)"
    else
      write_prefs
    fi
    ;;
  open)
    helium_running || write_prefs
    open -a Helium
    ;;
  *)
    echo "usage: theme-helium [apply|open]" >&2
    exit 2
    ;;
esac
